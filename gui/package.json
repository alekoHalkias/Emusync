{
  "name": "emusync-gui",
  "version": "0.1.0",
  "description": "EmuSync — LAN save-file sync for emulators",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && tsc -p tsconfig.renderer.json",
    "start": "npm run build && electron . --no-sandbox",
    "dev": "npm run build && electron . --no-sandbox",
    "dist": "npm run build && electron-builder --linux AppImage"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "typescript": "^5.3.0"
  },
  "build": {
    "appId": "com.emusync.app",
    "productName": "EmuSync",
    "files": [
      "dist/**/*",
      "renderer/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend/dist/emusync-backend",
        "to": "emusync-backend"
      }
    ],
    "linux": {
      "target": ["AppImage"],
      "category": "Game"
    }
  }
}
